{
    "name": "hagemann/default-docs-theme",
    "description": "Custom theme",
    "keywords": [
        "laravel",
        "larecipe"
    ],
    "license": "MIT",
    "require": {
        "php": ">=7.1.0"
    },
    "autoload": {
        "psr-4": {
            "Hagemann\\DefaultDocsTheme\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Hagemann\\DefaultDocsTheme\\ThemeServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
